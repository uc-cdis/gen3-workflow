plugins {
    id 'nf-ga4gh@1.0.0-PAULINE'
}
process {
    executor = 'tes'
    container = 'quay.io/nextflow/bash'
}
tes {
    endpoint = 'https://brhstaging.data-commons.org/ga4gh/tes'
    oauthToken = "${GEN3_TOKEN}"
    timeout = 30
    pollInterval = '5 sec'
    tags {
        _GPU = "${GPU}"
    }
}
aws {
    accessKey = "${GEN3_TOKEN}"
    secretKey = 'N/A'
    region = 'us-east-1'
    client {
        endpoint = ''https://brhstaging.data-commons.org/workflows/s3'
        s3PathStyleAccess = true
        maxErrorRetry = 0
    }
}
workDir = 's3://gen3wf-brhstaging-data-commons-org-35/ga4gh-tes'
